generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model MasterArea {
  id                 Int             @id @default(autoincrement())
  name               String          @unique
  latitude           Float           @default(0)
  longitude          Float           @default(0)
  city               String          @db.VarChar(100)
  normal_avg         Float           @default(0)
  warning_threshold  Float           @default(0)
  critical_threshold Float           @default(0)
  crowdPermits       CrowdPermit[]
  predictions        PredictionLog[]
}

model PredictionLog {
  id               Int        @id @default(autoincrement())
  areaId           Int
  prediction_date  DateTime
  volume_ton       Float
  confidence_score Float
  risk_status      String     @db.VarChar(50)
  createdAt        DateTime   @default(now())
  area             MasterArea @relation(fields: [areaId], references: [id])

  @@index([areaId], map: "PredictionLog_areaId_fkey")
}

model CrowdPermit {
  id              Int        @id @default(autoincrement())
  areaId          Int
  event_name      String
  event_date      DateTime
  estimated_crowd Int
  status          String     @db.VarChar(50)
  createdAt       DateTime   @default(now())
  area            MasterArea @relation(fields: [areaId], references: [id])

  @@index([areaId], map: "CrowdPermit_areaId_fkey")
}

model OperationalParam {
  id          Int    @id @default(autoincrement())
  param_key   String @unique
  param_value Float
}

model FleetInventory {
  id                     Int    @id @default(autoincrement())
  truck_type             String
  total_units            Int
  ready_units            Int
  capacity_per_truck_ton Float
}

model TpaFacility {
  id               Int    @id @default(autoincrement())
  name             String
  max_capacity_ton Float
  current_load_ton Float
}
